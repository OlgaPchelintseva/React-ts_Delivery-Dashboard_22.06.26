{
  "compilerOptions": {
    "target": "es2025",
    "lib": ["ES2025", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    // строгий контроль кода
    "strict": true, //полный набор строгих проверок типов
    "noImplicitAny": true, // запрет неявного присвоения типа any и невозможности вывода
    "strictNullChecks": true, // позволит разделять типы данных и значения null и undefind
    "strictFunctionTypes": true, 
    "noUnusedParameters": true, // запрет на неиспользуемые входные параметры
    "noUnusedLocals": true, // если есть неиспользуемые переменные
    "noFallthroughCasesInSwitch": true, 
    "skipLibCheck": true, // скипаем проверку модульных файлов
    
    // устанавливаем абсолютные пути
    "baseUrl": ".",
    "paths": {
      "@/*":["src/*"]
    }
  },
  "references": [{ "path": "./tsconfig.node.json" }],
  "include": ["src"]
}
